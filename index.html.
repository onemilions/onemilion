<script>
    // System Variables
    let currentUserId = null;
    let logoClickCount = 0;
    let logoTimer = null;

    const appLogic = {
        switchView(id) {
            document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
            document.getElementById(id + '-view').classList.add('active');
        },

        navTo(id, el) {
            this.switchView(id);
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            el.classList.add('active');
        },

        async login() {
            const phone = document.getElementById('login-phone').value.replace(/\s+/g, '');
            const pass = document.getElementById('login-password').value;

            if(!phone || !pass) return alert("Please fill all fields!");

            const userRef = window.fdb.ref(window.fdb.db, 'users/' + phone);
            const snapshot = await window.fdb.get(userRef);

            if(snapshot.exists()) {
                const data = snapshot.val();
                if(data.password === pass) {
                    currentUserId = phone;
                    localStorage.setItem('energy_uid', phone);
                    this.enterApp(data);
                } else {
                    alert("Invalid password!");
                }
            } else {
                alert("User not found!");
            }
        },

        async register() {
            const name = document.getElementById('reg-name').value;
            const phone = document.getElementById('reg-phone').value.replace(/\s+/g, '');
            const invite = document.getElementById('reg-invite').value;
            const pass = document.getElementById('reg-password').value;

            if(!name || !phone || !pass) return alert("Fill required fields!");
            if(pass.length < 6) return alert("Password too short!");

            const userRef = window.fdb.ref(window.fdb.db, 'users/' + phone);
            const check = await window.fdb.get(userRef);
            if(check.exists()) return alert("Phone already registered!");

            const myCode = 'EN-' + Math.floor(1000 + Math.random() * 9000);
            
            const userData = {
                fullName: name,
                phone: phone,
                password: pass,
                uplineCode: invite || "none",
                myCode: myCode,
                balance: 0.0,
                activePackage: "none",
                dailyProfit: 0,
                lastProfitUpdate: Date.now(),
                referrals: [] // Ще се пълни автоматично
            };

            await window.fdb.set(userRef, userData);

            // Реферална логика: Търсим кой е поканил този човек
            if(invite && invite !== "none") {
                this.updateReferralTree(invite, phone);
            }

            alert("Registration Successful!");
            this.switchView('login');
        },

        async updateReferralTree(inviteCode, newMemberPhone) {
            const usersRef = window.fdb.ref(window.fdb.db, 'users');
            const snapshot = await window.fdb.get(usersRef);
            
            if(snapshot.exists()) {
                const allUsers = snapshot.val();
                for(let key in allUsers) {
                    if(allUsers[key].myCode === inviteCode) {
                        const uplineRef = window.fdb.ref(window.fdb.db, `users/${key}/referrals`);
                        const currentRefs = allUsers[key].referrals || [];
                        currentRefs.push(newMemberPhone);
                        await window.fdb.set(uplineRef, currentRefs);
                        break;
                    }
                }
            }
        },

        enterApp(data) {
            document.getElementById('bottom-nav').style.display = 'flex';
            this.switchView('profile');
            this.startSync();
        },

        startSync() {
            const userRef = window.fdb.ref(window.fdb.db, 'users/' + currentUserId);
            window.fdb.onValue(userRef, (snapshot) => {
                const data = snapshot.val();
                if(!data) return;

                // Sync UI
                document.getElementById('ui-profile-name').innerText = data.fullName;
                document.getElementById('ui-profile-phone').innerText = "+" + data.phone;
                document.getElementById('ui-balance').innerText = data.balance.toFixed(2);
                document.getElementById('ui-wallet-balance').innerText = data.balance.toFixed(2);
                document.getElementById('ui-uid').innerText = data.phone;
                document.getElementById('ui-my-code').innerText = data.myCode;
                
                const pkgDisplay = document.getElementById('ui-active-package');
                pkgDisplay.innerText = data.activePackage !== "none" ? data.activePackage : "No Active Package";
                pkgDisplay.style.background = data.activePackage !== "none" ? "var(--success-green)" : "var(--admin-purple)";

                // Печалби на 24 часа
                this.checkDailyProfit(data);
                
                // Проверка за теглене
                this.checkWithdrawalEligibility(data);
            });
        },

        async checkDailyProfit(data) {
            if(data.activePackage === "none" || !data.dailyProfit) return;

            const now = Date.now();
            const oneDay = 24 * 60 * 60 * 1000;
            const lastUpdate = data.lastProfitUpdate || 0;

            if(now - lastUpdate >= oneDay) {
                const newBalance = (data.balance || 0) + parseFloat(data.dailyProfit);
                await window.fdb.update(window.fdb.ref(window.fdb.db, 'users/' + currentUserId), {
                    balance: newBalance,
                    lastProfitUpdate: now
                });
                console.log("Profit added!");
            }
        },

        async checkWithdrawalEligibility(userData) {
            const msgEl = document.getElementById('withdraw-msg');
            const btn = document.getElementById('btn-withdraw');
            const refs = userData.referrals || [];
            
            let hasActiveReferral = false;

            if(refs.length > 0) {
                // Проверяваме всеки реферал дали има пакет
                for(let refPhone of refs) {
                    const refSnap = await window.fdb.get(window.fdb.ref(window.fdb.db, 'users/' + refPhone));
                    if(refSnap.exists() && refSnap.val().activePackage !== "none") {
                        hasActiveReferral = true;
                        break;
                    }
                }
            }

            if(hasActiveReferral) {
                msgEl.innerHTML = `<i class="fas fa-unlock"></i> Withdrawal Unlocked: Eligibility verified.`;
                msgEl.style.color = "var(--success-green)";
                btn.disabled = false;
                btn.style.opacity = "1";
            } else {
                msgEl.innerHTML = `<i class="fas fa-lock"></i> Locked: You need 1 active referral to withdraw.`;
                msgEl.style.color = "var(--error-red)";
                btn.disabled = true;
                btn.style.opacity = "0.5";
            }
        },

        handleWithdraw() {
            const amount = parseFloat(document.getElementById('ui-balance').innerText);
            if(amount < 100) return alert("Minimum withdrawal is $100");
            alert("Request sent! Our team will process your payout within 24-48 hours.");
        },

        logout() {
            localStorage.clear();
            location.reload();
        }
    };

    const adminLogic = {
        trigger() {
            logoClickCount++;
            clearTimeout(logoTimer);
            logoTimer = setTimeout(() => { logoClickCount = 0; }, 2000);

            if(logoClickCount >= 5) {
                const pass = prompt("Enter Administration Password:");
                if(pass === "admin1234") {
                    appLogic.switchView('admin');
                } else {
                    alert("Access Denied.");
                }
                logoClickCount = 0;
            }
        },

        async updateUser() {
            const target = document.getElementById('admin-target-phone').value.replace(/\s+/g, '');
            const pkg = document.getElementById('admin-pkg-select').value;
            const profit = document.getElementById('admin-daily-profit').value;

            if(!target) return alert("Enter target phone!");

            const userRef = window.fdb.ref(window.fdb.db, 'users/' + target);
            const snap = await window.fdb.get(userRef);

            if(!snap.exists()) return alert("User not found in database!");

            await window.fdb.update(userRef, {
                activePackage: pkg,
                dailyProfit: parseFloat(profit || 0)
            });

            alert(`Success! User ${target} updated.`);
        }
    };

    // Auto-login
    window.onload = async () => {
        const saved = localStorage.getItem('energy_uid');
        if(saved) {
            const snap = await window.fdb.get(window.fdb.ref(window.fdb.db, 'users/' + saved));
            if(snap.exists()) {
                currentUserId = saved;
                appLogic.enterApp(snap.val());
            }
        }
    };
</script>

</body>
</html>
