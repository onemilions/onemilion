<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Invest In Energy ⚡️ Professional Edition</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        /* ========================================
           CORE DESIGN SYSTEM & VARIABLES
           ========================================
        */
        :root {
            --dark-green: #061f14;
            --dark-green-medium: #0c2e1f;
            --dark-green-light: #12452f;
            --bright-yellow: #FFD700;
            --soft-yellow: #ffec85;
            --gold-gradient: linear-gradient(135deg, #FFD700 0%, #b8860b 100%);
            --green-gradient: linear-gradient(145deg, #12452f, #082b1c);
            --text-light: #ffffff;
            --text-gray: #a0aab2;
            --error-red: #ff4d4d;
            --success-green: #00ff88;
            --admin-purple: #6c5ce7;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --radius: 12px;
            --shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        /* Basic Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            outline: none;
            -webkit-tap-highlight-color: transparent;
        }

        html, body {
            height: 100%;
            background-color: #000; /* Outer background */
            font-family: 'Montserrat', sans-serif;
            color: var(--text-light);
            overflow: hidden;
        }

        /* App Container (Mobile Wrapper) */
        #app-container {
            width: 100%;
            max-width: 480px;
            height: 100vh;
            background-color: var(--dark-green);
            margin: 0 auto;
            position: relative;
            display: flex;
            flex-direction: column;
            box-shadow: 0 0 50px rgba(0,255,136,0.1);
            overflow-y: auto;
            scrollbar-width: none; /* Firefox */
        }

        #app-container::-webkit-scrollbar {
            display: none; /* Chrome/Safari */
        }

        /* ========================================
           ANIMATIONS & TRANSITIONS
           ========================================
        */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes pulseYellow {
            0% { box-shadow: 0 0 0 0 rgba(255, 215, 0, 0.4); }
            70% { box-shadow: 0 0 0 15px rgba(255, 215, 0, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 215, 0, 0); }
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ========================================
           VIEW MANAGEMENT
           ========================================
        */
        .view {
            display: none;
            padding: 25px;
            padding-bottom: 100px;
            min-height: 100%;
            width: 100%;
            animation: fadeInUp 0.5s ease forwards;
        }

        .view.active {
            display: block;
        }

        /* ========================================
           HEADER & LOGO STYLES
           ========================================
        */
        .header-area {
            text-align: center;
            padding: 40px 0 20px;
        }

        .logo-title {
            font-size: 34px;
            font-weight: 900;
            color: var(--bright-yellow);
            text-transform: uppercase;
            letter-spacing: -1px;
            margin-bottom: 5px;
            cursor: pointer;
            user-select: none;
            transition: var(--transition);
        }

        .logo-title:active {
            transform: scale(0.95);
            opacity: 0.8;
        }

        .tagline {
            color: var(--text-gray);
            font-size: 13px;
            letter-spacing: 1px;
            font-weight: 400;
        }

        /* ========================================
           INPUTS & FORMS
           ========================================
        */
        .form-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            color: var(--bright-yellow);
            text-transform: uppercase;
            margin-bottom: 8px;
            margin-left: 5px;
            letter-spacing: 1px;
        }

        .input-box {
            background: var(--dark-green-medium);
            border: 1px solid rgba(255,215,0,0.1);
            border-radius: var(--radius);
            padding: 12px 15px;
            display: flex;
            align-items: center;
            margin-bottom: 20px;
            transition: var(--transition);
        }

        .input-box:focus-within {
            border-color: var(--bright-yellow);
            background: var(--dark-green-light);
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.1);
        }

        .input-box i {
            color: var(--bright-yellow);
            margin-right: 15px;
            width: 20px;
            text-align: center;
        }

        .input-box input, .input-box select {
            background: transparent;
            border: none;
            color: white;
            font-size: 16px;
            width: 100%;
            font-family: inherit;
        }

        /* ========================================
           BUTTONS
           ========================================
        */
        .btn-primary {
            background: var(--gold-gradient);
            color: var(--dark-green);
            border: none;
            border-radius: var(--radius);
            padding: 18px;
            font-size: 16px;
            font-weight: 800;
            width: 100%;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            transition: var(--transition);
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 215, 0, 0.2);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid var(--bright-yellow);
            color: var(--bright-yellow);
            padding: 15px;
            border-radius: var(--radius);
            font-weight: 700;
            text-transform: uppercase;
            cursor: pointer;
            width: 100%;
            transition: var(--transition);
        }

        .btn-outline:hover {
            background: rgba(255, 215, 0, 0.05);
        }

        /* ========================================
           CARDS & UI ELEMENTS
           ========================================
        */
        .card {
            background: var(--green-gradient);
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: var(--shadow);
        }

        .profile-header {
            text-align: center;
            padding: 20px 0;
        }

        .avatar-circle {
            width: 80px;
            height: 80px;
            background: var(--gold-gradient);
            border-radius: 50%;
            margin: 0 auto 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 35px;
            color: var(--dark-green);
            border: 4px solid var(--dark-green-light);
        }

        .package-tag {
            display: inline-block;
            background: var(--admin-purple);
            color: white;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            margin-top: 10px;
        }

        /* ========================================
           ADMIN PANEL SPECIFIC
           ========================================
        */
        #admin-view {
            background: #0d0d1a;
            border: 2px solid var(--admin-purple);
        }

        .admin-badge {
            background: var(--admin-purple);
            color: white;
            padding: 5px 15px;
            border-radius: 5px;
            font-size: 12px;
            margin-bottom: 20px;
            display: inline-block;
        }

        /* ========================================
           NAVIGATION
           ========================================
        */
        #bottom-nav {
            position: absolute;
            bottom: 0;
            width: 100%;
            background: rgba(6, 31, 20, 0.95);
            backdrop-filter: blur(10px);
            display: flex;
            justify-content: space-around;
            padding: 15px 5px;
            border-top: 1px solid rgba(255,215,0,0.1);
            z-index: 999;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: var(--text-gray);
            font-size: 10px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: var(--transition);
        }

        .nav-item i {
            font-size: 20px;
            margin-bottom: 5px;
        }

        .nav-item.active {
            color: var(--bright-yellow);
        }

        /* ========================================
           MODALS
           ========================================
        */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9);
            z-index: 10000;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(5px);
        }

        .modal-body {
            background: var(--dark-green-medium);
            width: 90%;
            max-width: 400px;
            padding: 30px;
            border-radius: 20px;
            border: 1px solid var(--bright-yellow);
            text-align: center;
        }
    </style>
</head>
